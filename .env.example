# =============================================================================
# B&F Website Environment Variables
# 이 파일을 .env.local로 복사한 뒤 실제 값을 입력하세요
# =============================================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://gbnf.kr

# --- Notion CMS ---
# https://www.notion.so/my-integrations 에서 발급
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 각 데이터베이스 URL의 32자리 ID (하이픈 제거)
# 예: https://www.notion.so/myworkspace/abcd1234... 의 abcd1234...
NOTION_DB_INSIGHTS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_CASES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_TEAM=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_SETTINGS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend (메일 발송) ---
# https://resend.com/api-keys 에서 발급
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=noreply@gbnf.kr
RESEND_TO=info@gbnf.kr

# --- Cloudflare Turnstile (스팸 방지) ---
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxx

# --- ISR Revalidate (Notion 웹훅용) ---
# 임의의 긴 문자열로 설정 (Make/Zapier 웹훅 인증용)
REVALIDATE_SECRET=your-random-secret-key-min-32-chars

# --- Analytics (선택) ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
